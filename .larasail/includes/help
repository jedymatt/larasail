#!/bin/bash

Color_Off="\033[0m"     # Text Reset
Yellow="\033[33m"       # Yellow

echo "${Yellow}Description:${Color_Off}"
echo "  LaraSail is a CLI for building Laravel ready servers on Digital Ocean"
echo ""

echo "${Yellow}Usage:${Color_Off}"
echo "  larasail $arguments"
echo ""

echo "${Yellow}Arguments:${Color_Off}"
echo "  ${Yellow}enter${Color_Off}              Enter shell as larasail user"
echo "  ${Yellow}setup${Color_Off}              Setup a new server with Nginx, PHP 8.4, and MySQL 8"
echo "  ${Yellow}setup php85${Color_Off}        Setup a new server with Nginx, PHP 8.5, and MySQL 8"
echo "  ${Yellow}setup php84${Color_Off}        Setup a new server with Nginx, PHP 8.4, and MySQL 8"
echo "  ${Yellow}setup php83${Color_Off}        Setup a new server with Nginx, PHP 8.3, and MySQL 8"
echo "  ${Yellow}setup php81${Color_Off}        Setup a new server with Nginx, PHP 8.1, and MySQL 8"
echo "  ${Yellow}setup php80${Color_Off}        Setup a new server with Nginx, PHP 8.0, and MySQL 8"
echo "  ${Yellow}setup mariadb${Color_Off}      Setup a new server with Nginx, PHP 8.4, and MariaDB 10.3"
echo "  ${Yellow}setup redis${Color_Off}        Setup a new server with Nginx, PHP 8.4, MySQL 8 and Redis Server"
echo "  ${Yellow}setup postgres${Color_Off}     Setup a new server with Nginx, PHP 8.4, MySQL 8 and PostgreSQL Server"
echo "  ${Yellow}new${Color_Off}                Create a new Laravel project using Larasail"
echo "  ${Yellow}project setup${Color_Off}      Configure cron + supervisor queue worker for an existing project"
echo "  ${Yellow}project cron${Color_Off}       Configure only the Laravel scheduler cron job"
echo "  ${Yellow}project queue${Color_Off}      Configure only the supervisor queue worker"
echo "  ${Yellow}host${Color_Off}               Create a new Nginx host"
echo "  ${Yellow}host \$1 \$2${Color_Off}         \$1=domain, \$2=folder_location (ex. larasail host url.com /var/www/folder)"
echo "  ${Yellow}pass${Color_Off}               Display the larasail user password"
echo "  ${Yellow}mysqlpass${Color_Off}.         Display the MySQL password"
echo "  ${Yellow}mysql fresh${Color_Off}        Purge and reinstall MySQL/MariaDB (destroys all databases)"
echo "  ${Yellow}database${Color_Off}           Database management"


#. /etc/.larasail/includes/colors
